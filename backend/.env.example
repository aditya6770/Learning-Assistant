# ── Server ───────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-random-string-in-production
JWT_SECRET_KEY=another-random-jwt-secret

# ── Database ──────────────────────────────────────────────────────────────────
# Local MongoDB
MONGO_URI=mongodb://localhost:27017/ai_learning_db
# MongoDB Atlas (cloud) — uncomment and fill in:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai_learning_db?retryWrites=true&w=majority

# ── External APIs (optional) ─────────────────────────────────────────────────
# YouTube Data API v3 key (for video recommendations)
YOUTUBE_API_KEY=

# ── Model Settings ────────────────────────────────────────────────────────────
# Set to 0 for GPU, -1 for CPU
DEVICE=-1

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50
